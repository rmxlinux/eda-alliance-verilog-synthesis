ENTITY top IS
PORT(
  sel : in BIT;
  a : in BIT;
  b : in BIT;
  c : in BIT;
  y : out BIT
);
END top;

ARCHITECTURE behavior_data_flow OF top IS
  SIGNAL t : BIT;
  SIGNAL u_stage__nb : BIT;
BEGIN
  u_stage__nb <= (not b);
  t <= ((sel and u_stage__nb) or ((not sel) and a));
  y <= ((sel and c) or ((not sel) and t));
END behavior_data_flow;
