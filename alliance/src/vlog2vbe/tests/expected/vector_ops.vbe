ENTITY vector_ops IS
PORT(
  a : in BIT_VECTOR(3 downto 0);
  b : in BIT_VECTOR(3 downto 0);
  y : out BIT_VECTOR(3 downto 0);
  y0 : out BIT;
  vdd : in BIT;
  vss : in BIT
);
END vector_ops;

ARCHITECTURE behavior_data_flow OF vector_ops IS
  SIGNAL n : BIT_VECTOR(3 downto 0);
BEGIN
  ASSERT ((vdd and not (vss)) = '1')
  REPORT "power supply is missing on vector_ops"
  SEVERITY WARNING;
  n <= (a xor b);
  y <= (n or B"0011");
  y0 <= n(0);
END behavior_data_flow;
