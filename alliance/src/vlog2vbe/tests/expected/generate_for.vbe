ENTITY top IS
PORT(
  a : in BIT_VECTOR(3 downto 0);
  b : in BIT_VECTOR(3 downto 0);
  y : out BIT_VECTOR(3 downto 0);
  n : out BIT_VECTOR(3 downto 0);
  vdd : in BIT;
  vss : in BIT
);
END top;

ARCHITECTURE behavior_data_flow OF top IS
BEGIN
  ASSERT ((vdd and not (vss)) = '1')
  REPORT "power supply is missing on top"
  SEVERITY WARNING;
  y(0) <= (a(0) and b(0));
  n(0) <= (((not (('0' xor '1') or ('0' xor '1'))) and (not a(0))) or ((not (not (('0' xor '1') or ('0' xor '1')))) and a(0)));
  y(1) <= (a(1) and b(1));
  n(1) <= (((not (('1' xor '1') or ('0' xor '1'))) and (not a(1))) or ((not (not (('1' xor '1') or ('0' xor '1')))) and a(1)));
  y(2) <= (a(2) and b(2));
  n(2) <= (((not (('0' xor '1') or ('1' xor '1'))) and (not a(2))) or ((not (not (('0' xor '1') or ('1' xor '1')))) and a(2)));
  y(3) <= (a(3) and b(3));
  n(3) <= (((not (('1' xor '1') or ('1' xor '1'))) and (not a(3))) or ((not (not (('1' xor '1') or ('1' xor '1')))) and a(3)));
END behavior_data_flow;
