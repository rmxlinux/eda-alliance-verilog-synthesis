ENTITY always_mux IS
PORT(
  sel : in BIT;
  a : in BIT;
  b : in BIT;
  y : out BIT;
  vdd : in BIT;
  vss : in BIT
);
END always_mux;

ARCHITECTURE behavior_data_flow OF always_mux IS
BEGIN
  ASSERT ((vdd and not (vss)) = '1')
  REPORT "power supply is missing on always_mux"
  SEVERITY WARNING;
  y <= ((sel and a) or ((not sel) and b));
END behavior_data_flow;
