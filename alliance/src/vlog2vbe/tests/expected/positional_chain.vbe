ENTITY top IS
PORT(
  a : in BIT;
  b : in BIT;
  y : out BIT;
  vdd : in BIT;
  vss : in BIT
);
END top;

ARCHITECTURE behavior_data_flow OF top IS
  SIGNAL na : BIT;
BEGIN
  ASSERT ((vdd and not (vss)) = '1')
  REPORT "power supply is missing on top"
  SEVERITY WARNING;
  na <= (not a);
  y <= (na xor b);
END behavior_data_flow;
