ENTITY top IS
PORT(
  clk : in BIT;
  a : in BIT;
  b : in BIT;
  q : out BIT;
  vdd : in BIT;
  vss : in BIT
);
END top;

ARCHITECTURE behavior_data_flow OF top IS
  SIGNAL q_reg : REG_BIT REGISTER;
  SIGNAL d : BIT;
BEGIN
  ASSERT ((vdd and not (vss)) = '1')
  REPORT "power supply is missing on top"
  SEVERITY WARNING;
  label0 : BLOCK ((clk and not (clk'STABLE)) = '1')
  BEGIN
    q_reg <= GUARDED d;
  END BLOCK label0;
  d <= (a xor b);
  q <= q_reg;
END behavior_data_flow;
